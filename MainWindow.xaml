<Window x:Class="RemotePlayLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RemotePlayLauncher"
        Title="Coop Launcher"
        Icon="pack://application:,,,/icon.ico"
        Width="1120" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#121118"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Purple Hue Theme: #5F5980 -->
        <SolidColorBrush x:Key="AccentBrush" Color="#5F5980"/>
        <SolidColorBrush x:Key="AccentLighterBrush" Color="#7A74A0"/>
        <SolidColorBrush x:Key="BgDarkBrush" Color="#121118"/>
        <SolidColorBrush x:Key="HeaderBgBrush" Color="#1A1826"/>
        <SolidColorBrush x:Key="RowBgBrush" Color="#1E1D2B"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#EBEBEB"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="#908CA0"/>

        <!-- Slim scrollbar -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="2" Background="#3E3A4D" Margin="1,5"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" Style="{StaticResource ThinScrollBar}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Game row button -->
        <Style x:Key="GameRow" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource RowBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="12" Margin="0,3"
                                BorderBrush="#2A283D" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#29273D"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A3654"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header / toolbar button -->
        <Style x:Key="HeaderBtn" TargetType="Button">
            <Setter Property="Background" Value="#252433"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#323045"/>
                                <Setter Property="Foreground" Value="#F0F0F0"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search textbox -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource RowBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A283D"/>
            <Setter Property="Padding" Value="46,13"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="Border" Background="{TemplateBinding Background}" 
                                CornerRadius="12" BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Context Menu theme -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#1A1826"/>
            <Setter Property="BorderBrush" Value="#2D2B3D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="6" Margin="2,1">
                            <Grid>
                                <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#29273D"/>
                                <Setter Property="Foreground" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid x:Name="RootSurface" Background="#121118">
        <local:OverlayFrameSurface x:Name="OverlayFrame" Panel.ZIndex="-1"/>
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header    -->
            <RowDefinition Height="Auto"/>   <!-- search    -->
            <RowDefinition Height="*"/>      <!-- list      -->
            <RowDefinition Height="Auto"/>   <!-- statusbar -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}" Padding="24,20,24,18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center">
                    <TextBlock Text="Coop Launcher"
                               FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}"/>
                    <TextBlock x:Name="SubtitleText" Text="Loading games…"
                               FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,14,0,0">
                    <WrapPanel Orientation="Horizontal">
                        <Button x:Name="AddGameBtn" Content="＋  Añadir"
                                Margin="0,0,8,0" Style="{StaticResource HeaderBtn}"
                                Click="AddGameBtn_Click"
                                ToolTip="Añadir accesos directos o ejecutables externos"/>
                        <Button x:Name="OpenWindowBtn" Content="▣  App abierta"
                                Margin="0,0,8,0" Style="{StaticResource HeaderBtn}"
                                Click="OpenWindowBtn_Click"
                                ToolTip="Reiniciar una aplicación abierta dentro de la sesión de Steam"/>
                        <Button x:Name="OverlayBtn" Content="🎮  Controles"
                                Margin="0,0,8,0" Style="{StaticResource HeaderBtn}"
                                Click="OverlayBtn_Click"
                                ToolTip="Maximizar para abrir el panel de Remote Play con Shift+Tab"/>
                        <Button x:Name="GuestModeBtn" Content="⇲  Invitado"
                                Style="{StaticResource HeaderBtn}"
                                Click="GuestModeBtn_Click"
                                ToolTip="Cerrar la sesión anfitriona antes de aceptar una invitación de Remote Play"/>
                    </WrapPanel>
                    <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="RepairSteamBtn" Content="🛠  Reparar Steam"
                                Margin="0,0,8,0" Style="{StaticResource HeaderBtn}"
                                Click="RepairSteamBtn_Click"
                                ToolTip="Detectar y desactivar modificaciones de Steam que bloquean Remote Play"/>
                        <Button x:Name="RefreshBtn" Content="↻  Actualizar"
                                Margin="0,0,8,0" Style="{StaticResource HeaderBtn}"
                                Click="RefreshBtn_Click"/>
                        <Button x:Name="SettingsBtn" Content="⚙  Donante"
                                Margin="0,0,8,0" Style="{StaticResource HeaderBtn}"
                                Click="SettingsBtn_Click"
                                ToolTip="Configure which Steam game hosts Remote Play Together"/>
                        <Button x:Name="CreditsBtn" Content="Acerca de"
                                Style="{StaticResource HeaderBtn}"
                                Click="CreditsBtn_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ SEARCH ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource HeaderBgBrush}" Padding="16,0,16,16">
            <Grid>
                <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}"
                         TextChanged="SearchBox_TextChanged"/>
                <!-- Magnifier + placeholder -->
                <StackPanel Orientation="Horizontal" IsHitTestVisible="False"
                            Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="⌕" FontSize="18" Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="SearchHint" Text="Buscar juegos y aplicaciones…"
                               FontSize="14" Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ GAME LIST ════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2"
                      Style="{StaticResource DarkScrollViewer}"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,4,16,4">
            <StackPanel x:Name="GameList" Margin="0,4,0,12">
                <TextBlock x:Name="LoadingText"
                           Text="Escaneando la biblioteca de Steam…"
                           Foreground="{StaticResource TextDimBrush}" FontSize="14" FontFamily="Segoe UI"
                           HorizontalAlignment="Center" Margin="0,80,0,0"/>
                <TextBlock x:Name="NoResultsText"
                           Text="No hay resultados para esta búsqueda."
                           Foreground="{StaticResource TextDimBrush}" FontSize="14" FontFamily="Segoe UI"
                           HorizontalAlignment="Center" Margin="0,80,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ══ STATUS BAR ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#0C0B12" Padding="20,10">
            <TextBlock x:Name="StatusText"
                       Foreground="{StaticResource TextDimBrush}" FontSize="11" FontFamily="Segoe UI"
                       TextWrapping="Wrap">
                <Run x:Name="DonorRun" Text="No hay donante configurado."/>
            </TextBlock>
        </Border>
        </Grid>

        <!-- This picker deliberately lives inside the donor HWND. Opening a
             second native window makes Steam Remote Play Together switch to
             Desktop Placeholder and disable the guest's input. -->
        <Grid x:Name="WindowPickerOverlay"
              Panel.ZIndex="30"
              Visibility="Collapsed"
              Background="#EE0B0A10">
            <Border Width="820" MaxWidth="920" MaxHeight="650"
                    Margin="28" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="16" Background="#1A1826"
                    BorderBrush="#403B58" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Abrir una aplicación dentro de Steam"
                                       Foreground="{StaticResource TextMainBrush}"
                                       FontSize="21" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,7,16,0"
                                       Foreground="{StaticResource TextDimBrush}"
                                       TextWrapping="Wrap"
                                       Text="Remote Play Together bloquea las ventanas que ya estaban abiertas. Selecciona una aplicación para cerrarla de forma normal y volver a iniciarla como parte del juego donante; así Steam puede transmitirla y habilitar los controles."/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕" Width="42" Height="38"
                                Style="{StaticResource HeaderBtn}"
                                Click="WindowPickerCancel_Click"/>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,18,0,12" Padding="12,9"
                            Background="#252235" CornerRadius="8">
                        <TextBlock x:Name="WindowPickerStatus"
                                   Foreground="#C9C5D6" TextWrapping="Wrap"
                                   Text="Selecciona la aplicación que quieres incorporar a la sesión."/>
                    </Border>

                    <ListBox x:Name="RunningWindowList" Grid.Row="2"
                             MinHeight="210" MaxHeight="350"
                             Background="#121118" BorderBrush="#2D2B3D"
                             BorderThickness="1" Foreground="{StaticResource TextMainBrush}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="RunningWindowList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="13,10"/>
                                <Setter Property="Margin" Value="3,2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#29273D"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#3A3654"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="14"
                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ExecutablePath}" Margin="0,3,0,0"
                                               FontSize="11" Foreground="{StaticResource TextDimBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3" Margin="0,12,0,0">
                        <CheckBox x:Name="WindowRestartConsent"
                                  Foreground="#E8DDBD" VerticalContentAlignment="Center">
                            <TextBlock TextWrapping="Wrap"
                                       Text="Ya guardé mi trabajo. Autorizo cerrar esta aplicación normalmente y volver a abrirla sin permisos de administrador."/>
                        </CheckBox>
                        <Border x:Name="DesktopLimitationNotice" Visibility="Collapsed"
                                Margin="0,10,0,0" Padding="12" CornerRadius="8"
                                Background="#332A1E" BorderBrush="#6C5430" BorderThickness="1">
                            <TextBlock Foreground="#F0D59B" TextWrapping="Wrap"
                                       Text="El escritorio completo no es compatible con invitados de Remote Play Together: Steam lo reemplaza por ‘Host busy’ por privacidad. Para controlar todo el escritorio utiliza Steam Link, Sunshine/Moonlight o una herramienta de escritorio remoto; esta sesión seguirá funcionando para aplicaciones iniciadas desde Coop Launcher."/>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="4" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" HorizontalAlignment="Left"
                                Content="¿Por qué no el escritorio?"
                                Style="{StaticResource HeaderBtn}"
                                Click="DesktopExplanation_Click"/>
                        <Button Grid.Column="1" Content="Actualizar" Margin="0,0,8,0"
                                Style="{StaticResource HeaderBtn}"
                                Click="WindowPickerRefresh_Click"/>
                        <Button Grid.Column="2" Content="Cancelar" Margin="0,0,8,0"
                                Style="{StaticResource HeaderBtn}"
                                Click="WindowPickerCancel_Click"/>
                        <Button x:Name="RestartWindowBtn" Grid.Column="3"
                                Content="Cerrar y abrir dentro de Steam"
                                Padding="18,9" Style="{StaticResource HeaderBtn}"
                                Click="RestartWindowInsideSteam_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
